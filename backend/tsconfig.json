{
  "compilerOptions": {
    /* Runtime & Language */
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],

    /* Directory Structure */
    "rootDir": "src",
    "outDir": "dist",

    /* Type Safety */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,

    /* Node Compatibility */
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"],

    /* Build Behavior */
    "skipLibCheck": true,
    "sourceMap": true,
    "removeComments": true,
    "noEmitOnError": true,
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}